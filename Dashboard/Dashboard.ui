    }
    QPushButton.menu-btn:hover {
        background-color: rgba(255, 255, 255, 25);
        color: #ffffff;
    }
    QPushButton.menu-btn:checked {
        background: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:0, stop:0 #a855f7, stop:1 #ec4899);
        color: #ffffff;
    }
    QPushButton#btnMenuLogout {
