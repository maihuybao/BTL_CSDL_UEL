    }
    QPushButton#btnSua:hover {
        background-color: #d97706;
    }
    QPushButton#btnXoa {
        background-color: #ef4444;
        color: #ffffff;
        border: none;
    }
    QPushButton#btnXoa:hover {
        background-color: #dc2626;
    }
    QPushButton#btnRefresh, QPushButton#btnHuy, QPushButton#btnXuatExcel {
        background-color: #ffffff;
        border: 1px solid #cbd5e1;
        color: #475569;
    }
    QPushButton#btnRefresh:hover, QPushButton#btnHuy:hover, QPushButton#btnXuatExcel:hover {
        background-color: #f1f5f9;
        color: #1e293b;
    }
    QTableWidget {
        background-color: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        gridline-color: #f1f5f9;
    }
    QHeaderView::section {
