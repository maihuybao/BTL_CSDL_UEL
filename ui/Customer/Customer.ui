        border: 1px solid #cbd5e1;
        border-radius: 6px;
        padding: 8px 10px;
        font-size: 13px;
        color: #334155;
        background-color: #ffffff;
    }
    QLineEdit:focus {
        border: 2px solid #a855f7;
    }
    QPushButton {
        border-radius: 6px;
        font-weight: 500;
        font-size: 13px;
        padding: 8px 15px;
        height: 34px;
    }
    QPushButton#btnSearch, QPushButton#btnLuu {
        background: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:0, stop:0 #7c3aed, stop:1 #ec4899);
        color: #ffffff;
        border: none;
    }
    QPushButton#btnSearch:hover, QPushButton#btnLuu:hover {
        background: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:0, stop:0 #6d28d9, stop:1 #db2777);
    }
    QPushButton#btnThem {
