create table NGUOI_BAN(
	MaNguoiBan varchar(10) not null primary key,
	MatKhau varchar(50), -- Đã thêm để khớp dữ liệu file 3
	HoTen text,
	SoDienThoai varchar(10),
	Email varchar(40),
	TenCuaHang text,
	DiaChi text
);

create table SAN_PHAM(
	MaSP varchar(10) not null primary key,
	TenSP text,
	MoTa text, -- Đổi từ nvarchar(max)
	GiaBan float,
	SoLuongTon int,
	HinhAnh varchar(255)
);

create table VOUCHER(
	MaVoucher varchar(10) not null primary key,
	TenVoucher text,
	GiaTriGiam float,
	DieuKienApDung text,
	NgayBatDau text,
	NgayKetThuc text,
	TrangThai text
);

create table LIVESTREAM(
	MaLive varchar(10) not null primary key,
	MaNguoiBan varchar(10) not null,
	TenLive text,
	ThoiGianBatDau text,
	ThoiGianKetThuc text,
	TrangThai text,
	foreign key (MaNguoiBan) references NGUOI_BAN(MaNguoiBan)
);

create table BINH_LUAN(
	MaBinhLuan varchar(10) not null primary key,
	MaLive varchar(10) not null,
	NoiDung text, -- Đổi từ nvarchar(max)
	ThoiGian text,
	NguoiBinhLuan text,
	LoaiBinhLuan text,
	foreign key (MaLive) references LIVESTREAM(MaLive)
);

create table KHACH_HANG(
	MaKhachHang varchar(10) not null primary key,
	HoTen text,
	SoDienThoai varchar(10),
	Email varchar(40),
	DiaChi text
);

create table DON_HANG(
	MaDonHang varchar(10) not null primary key,
	MaKhachHang varchar(10), -- Đã thêm để khớp dữ liệu file 3
	MaBinhLuan varchar(10),
	MaVoucher varchar(10),
	NgayDat text,
	TongTien float,
	TrangThaiDH text,
	foreign key (MaKhachHang) references KHACH_HANG(MaKhachHang),
	foreign key (MaBinhLuan) references BINH_LUAN(MaBinhLuan),
	foreign key (MaVoucher) references VOUCHER(MaVoucher)
);

create table CHI_TIET_DON_HANG(
	MaDonHang varchar(10) not null,
	MaSP varchar(10) not null,
	SoLuong int,
	DonGia float,
	ThanhTien float,
	primary key (MaDonHang, MaSP),
	foreign key (MaDonHang) references DON_HANG(MaDonHang),
	foreign key (MaSP) references SAN_PHAM(MaSP)
);

create table HOA_DON(
	MaHoaDon varchar(10) not null primary key,
	MaDonHang varchar(10) not null,
	PhuongThucTT text,
	TongTien float,
	ThoiGianLap text,
	TrangThaiHD text,
	foreign key (MaDonHang) references DON_HANG(MaDonHang)
);

create table LIVESTREAM_SAN_PHAM(
	MaLive varchar(10) not null,
	MaSP varchar(10) not null,
	primary key (MaLive, MaSP),
	foreign key (MaLive) references LIVESTREAM(MaLive),
	foreign key (MaSP) references SAN_PHAM(MaSP)
);