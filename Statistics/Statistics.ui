  <property name="styleSheet">
   <string notr="true">
    QWidget {
        background: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:1, stop:0 #f5f3ff, stop:0.5 #fdf4ff, stop:1 #fff7ed);
        font-family: &quot;Segoe UI&quot;;
    }
    QLabel#lblTitle {
        font-size: 18px;
        font-weight: bold;
        color: #7c3aed;
    }
    QLabel#lblSubtitle {
        color: #64748b;
        font-size: 12px;
    }
    QGroupBox {
        font-weight: bold;
        color: #1e293b;
        border: 1px solid #e9d5ff;
        border-radius: 8px;
        margin-top: 10px;
        padding-top: 15px;
        background-color: #ffffff;
    }
    QGroupBox::title {
        subcontrol-origin: margin;
        subcontrol-position: top left;
        left: 15px;
        padding: 0 5px;
    }
    QFrame#cardRevenue, QFrame#cardOrders, QFrame#cardAvgValue {
        background-color: #ffffff;
        border: 1px solid #e9d5ff;
        border-radius: 8px;
    }
    QFrame#cardRevenue { border-left: 4px solid #7c3aed; }
    QFrame#cardOrders { border-left: 4px solid #ec4899; }
    QFrame#cardAvgValue { border-left: 4px solid #fb923c; }
    QLabel.lblCardTitle {
        color: #64748b;
        font-size: 13px;
        font-weight: 500;
    }
    QLabel.lblCardValue {
        color: #7c3aed;
        font-size: 20px;
        font-weight: bold;
    }
    QDateEdit {
        border: 1px solid #cbd5e1;
        border-radius: 6px;
        padding: 6px 10px;
        font-size: 13px;
        color: #334155;
        background-color: #ffffff;
    }
    QDateEdit:focus {
        border: 2px solid #a855f7;
    }
    QPushButton {
        border-radius: 6px;
        font-weight: 500;
        font-size: 13px;
        padding: 8px 15px;
        height: 34px;
    }
    QPushButton#btnFilter {
        background: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:0, stop:0 #7c3aed, stop:1 #ec4899);
        color: #ffffff;
        border: none;
    }
    QPushButton#btnFilter:hover {
        background: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:0, stop:0 #6d28d9, stop:1 #db2777);
    }
    QPushButton#btnRefresh, QPushButton#btnXuatExcel {
        background-color: #ffffff;
        border: 1px solid #cbd5e1;
        color: #475569;
    }
    QPushButton#btnRefresh:hover, QPushButton#btnXuatExcel:hover {
        background-color: #f1f5f9;
        color: #1e293b;
    }
    QTableWidget {
        background-color: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        gridline-color: #f1f5f9;
    }
    QHeaderView::section {
        background: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:0, stop:0 #7c3aed, stop:1 #ec4899);
        color: #ffffff;
        font-weight: bold;
        font-size: 12px;
        border: none;
        padding: 8px;
    }
    QTableWidget::item:selected {
        background-color: #f3e8ff;
        color: #7c3aed;
    }
    QFrame#frameChart {
        background-color: #ffffff;
        border: 1px solid #e9d5ff;
        border-radius: 8px;
    }
   </string>
