    }
    QPushButton#btnXoa {
        background-color: #ef4444;
        color: #ffffff;
        border: none;
    }
    QPushButton#btnXoa:hover {
        background-color: #dc2626;
    }
    QPushButton#btnRefresh, QPushButton#btnHuy, QPushButton#btnXuatExcel, QPushButton#btnSelectImage {
        background-color: #ffffff;
        border: 1px solid #cbd5e1;
        color: #475569;
    }
    QPushButton#btnRefresh:hover, QPushButton#btnHuy:hover, QPushButton#btnXuatExcel:hover, QPushButton#btnSelectImage:hover {
        background-color: #f1f5f9;
        color: #1e293b;
    }
    QLabel#lblImagePreview {
        border: 1px dashed #cbd5e1;
        border-radius: 8px;
        background: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:1, stop:0 #f5f3ff, stop:0.5 #fdf4ff, stop:1 #fff7ed);
